{
	"name": "@ctx-core/dialog-ui-solid",
	"version": "2.3.239",
	"keywords": [
		"ctx-core",
		"dialog"
	],
	"homepage": "https://github.com/ctx-core/dialog-ui-solid#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/dialog-ui-solid/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/dialog-ui-solid.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-dialog-ui-solid@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"./ui"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.jsx",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "uvu . '\\.test\\.(ts|tsx|js|jsx)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"@ctx-core/dom": "*",
		"@ctx-core/nanostores": "*",
		"@ctx-core/solid-js": "*",
		"@ctx-core/ui-solid": "*",
		"ctx-core": "*",
		"solid-js": "1.9.11"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	}
}
